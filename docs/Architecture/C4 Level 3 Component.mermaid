{"title":"C4 Level 3 — Component (VPNManager.exe)","diagramCode":"C4Component\n  title Component Diagram — VPNManager.exe internals\n\n  Person(user, \"User\")\n\n  System_Boundary(exe, \"VPNManager.exe\") {\n    Component(mainform, \"MainForm\", \"WinForms Form\", \"God node. Owns cycle timer, status display, system tray icon. Orchestrates all services.\")\n    Component(settingsform, \"SettingsForm\", \"WinForms Form\", \"UI for VPN type, cycle duration, MEGAsync path, theme selection.\")\n    Component(aboutdlg, \"AboutDialog\", \"WinForms Form\", \"Version info, custom-drawn icon, Obsidian theme.\")\n    Component(vpnsvc, \"VpnService\", \"C# Service\", \"Spawns VPN-AutoToggle.ps1, writes vpn-settings.json, monitors PowerShell process.\")\n    Component(megasvc, \"MegaService\", \"C# Service\", \"Finds MEGAsync.exe via registry/common paths, kills and restarts it.\")\n    Component(appsettings, \"AppSettings\", \"Model + JSON persistence\", \"Serializes/deserializes settings.json. Shared by MainForm, SettingsForm, VpnService.\")\n    Component(themeutils, \"ThemeUtils\", \"Static utility\", \"Detects system dark/light mode, applies Obsidian-style theme to all controls.\")\n    Component(program, \"Program.cs\", \"Entry point\", \"Single-instance mutex guard. Creates and runs MainForm.\")\n  }\n\n  ContainerDb(settingsjson, \"settings.json\", \"AppData JSON\")\n  ContainerDb(vpnsettingsjson, \"vpn-settings.json\", \"Temp JSON\")\n  System_Ext(ps1, \"VPN-AutoToggle.ps1\", \"PowerShell script\")\n  System_Ext(mega, \"MEGAsync.exe\", \"External process\")\n\n  Rel(user, mainform, \"Start/stop, view status\")\n  Rel(user, settingsform, \"Configure preferences\")\n  Rel(program, mainform, \"Instantiates on startup\")\n  Rel(mainform, vpnsvc, \"Start/stop VPN cycle\")\n  Rel(mainform, megasvc, \"Trigger MEGAsync restart\")\n  Rel(mainform, settingsform, \"Open settings dialog\")\n  Rel(mainform, aboutdlg, \"Open about dialog\")\n  Rel(mainform, themeutils, \"Apply theme on load + settings change\")\n  Rel(settingsform, appsettings, \"Read/write preferences\")\n  Rel(vpnsvc, appsettings, \"Read VPN type, cycle duration\")\n  Rel(vpnsvc, vpnsettingsjson, \"Write runtime VPN params\")\n  Rel(vpnsvc, ps1, \"Spawn process\")\n  Rel(megasvc, appsettings, \"Read MEGAsync path\")\n  Rel(megasvc, mega, \"Kill + restart\")\n  Rel(appsettings, settingsjson, \"Load() / Save()\")","valid":true,"renderedSVG":"data:image/svg+xml;base64,","renderedPNG":"data:image/png;base64,","rawSVG":"<style>foreignObject div { overflow: visible !important; }</style><svg id=\"mermaid-1779411942427\" width=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" style=\"max-width: 961px;\" viewBox=\"0 -70 961 2607\" role=\"graphics-document document\" aria-roledescription=\"c4\"><style>#mermaid-1779411942427{font-family:\"trebuchet ms\",verdana,arial,sans-serif;font-size:16px;fill:#333;}@keyframes edge-animation-frame{from{stroke-dashoffset:0;}}@keyframes dash{to{stroke-dashoffset:0;}}#mermaid-1779411942427 .edge-animation-slow{stroke-dasharray:9,5!important;stroke-dashoffset:900;animation:dash 50s linear infinite;stroke-linecap:round;}#mermaid-1779411942427 .edge-animation-fast{stroke-dasharray:9,5!important;stroke-dashoffset:900;animation:dash 20s linear infinite;stroke-linecap:round;}#mermaid-1779411942427 .error-icon{fill:#552222;}#mermaid-1779411942427 .error-text{fill:#552222;stroke:#552222;}#mermaid-1779411942427 .edge-thickness-normal{stroke-width:1px;}#mermaid-1779411942427 .edge-thickness-thick{stroke-width:3.5px;}#mermaid-1779411942427 .edge-pattern-solid{stroke-dasharray:0;}#mermaid-1779411942427 .edge-thickness-invisible{stroke-width:0;fill:none;}#mermaid-1779411942427 .edge-pattern-dashed{stroke-dasharray:3;}#mermaid-1779411942427 .edge-pattern-dotted{stroke-dasharray:2;}#mermaid-1779411942427 .marker{fill:#333333;stroke:#333333;}#mermaid-1779411942427 .marker.cross{stroke:#333333;}#mermaid-1779411942427 svg{font-