{"title":"C4 Level 2 — Container","diagramCode":"C4Container\n  title Container Diagram — VPN Manager System\n\n  Person(user, \"User\", \"Interacts via system tray / GUI\")\n\n  System_Boundary(vpnmgr, \"VPN Manager\") {\n    Container(gui, \"VPNManager.exe\", \"C# WinForms / .NET\", \"System tray GUI. Manages cycle timer, settings, process lifecycle.\")\n    Container(ps1, \"VPN-AutoToggle.ps1\", \"PowerShell 5.1+\", \"Core toggle loop. Connects/disconnects VPN, waits cycle duration, logs state.\")\n    ContainerDb(settingsjson, \"settings.json\", \"JSON / AppData\", \"Persistent user config: VPN type, cycle time, MEGAsync path, theme.\")\n    ContainerDb(vpnsettingsjson, \"vpn-settings.json\", \"JSON / Temp\", \"Runtime bridge: GUI writes VPN params, PowerShell reads them to avoid CLI credential exposure.\")\n  }\n\n  System_Ext(warp, \"Cloudflare WARP\", \"warp-cli\")\n  System_Ext(mega, \"MEGAsync.exe\", \"Desktop client process\")\n  System_Ext(winvpn, \"rasdial / Windows VPN\", \"Built-in Windows VPN\")\n\n  Rel(user, gui, \"Start/stop cycle, configure settings\")\n  Rel(gui, ps1, \"Spawns PowerShell process with parameters\")\n  Rel(gui, settingsjson, \"Read/write user preferences\")\n  Rel(gui, vpnsettingsjson, \"Write VPN credentials + type at runtime\")\n  Rel(ps1, vpnsettingsjson, \"Read VPN type and credentials\")\n  Rel(ps1, warp, \"warp-cli connect / disconnect\")\n  Rel(ps1, winvpn, \"rasdial connect / disconnect\")\n  Rel(ps1, mega, \"Kill + restart process after each toggle\")\n  Rel(gui, mega, \"Monitor process status, display in UI\")","valid":true,"renderedSVG":"data:image/svg+xml;base64,","renderedPNG":"data:image/png;base64,","rawSVG":"<style>foreignObject div { overflow: visible !important; }</style><svg id=\"mermaid-1779411935568\" width=\"100%\" xmlns=\"http://www.w3.org/2000/svg\" xmlns:xlink=\"http://www.w3.org/1999/xlink\" style=\"max-width: 1032px;\" viewBox=\"0 -70 1032 1632\" role=\"graphics-document document\" aria-roledescription=\"