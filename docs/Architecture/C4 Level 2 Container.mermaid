t-anchor: middle; font-size: 16px; font-weight: bold; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">User</tspan></text><text x=\"258\" y=\"289\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Interacts via system tray / GUI</tspan></text></g><g class=\"person-man\"><rect x=\"466\" y=\"166\" fill=\"#999999\" stroke=\"#8A8A8A\" width=\"216\" height=\"86\" rx=\"2.5\" ry=\"2.5\" stroke-width=\"0.5\"></rect><text fill=\"#FFFFFF\" font-family=\"&quot;Open Sans&quot;, sans-serif\" font-size=\"12\" font-style=\"italic\" lengthAdjust=\"spacing\" textLength=\"101\" x=\"523.5\" y=\"186\">&lt;&lt;external_system&gt;&gt;</text><text x=\"574\" y=\"204\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 16px; font-weight: bold; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Cloudflare WARP</tspan></text><text x=\"574\" y=\"241\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">warp-cli</tspan></text></g><g class=\"person-man\"><rect x=\"150\" y=\"400\" fill=\"#999999\" stroke=\"#8A8A8A\" width=\"216\" height=\"86\" rx=\"2.5\" ry=\"2.5\" stroke-width=\"0.5\"></rect><text fill=\"#FFFFFF\" font-family=\"&quot;Open Sans&quot;, sans-serif\" font-size=\"12\" font-style=\"italic\" lengthAdjust=\"spacing\" textLength=\"101\" x=\"207.5\" y=\"420\">&lt;&lt;external_system&gt;&gt;</text><text x=\"258\" y=\"438\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 16px; font-weight: bold; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">MEGAsync.exe</tspan></text><text x=\"258\" y=\"475\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Desktop client process</tspan></text></g><g class=\"person-man\"><rect x=\"466\" y=\"400\" fill=\"#999999\" stroke=\"#8A8A8A\" width=\"216\" height=\"86\" rx=\"2.5\" ry=\"2.5\" stroke-width=\"0.5\"></rect><text fill=\"#FFFFFF\" font-family=\"&quot;Open Sans&quot;, sans-serif\" font-size=\"12\" font-style=\"italic\" lengthAdjust=\"spacing\" textLength=\"101\" x=\"523.5\" y=\"420\">&lt;&lt;external_system&gt;&gt;</text><text x=\"574\" y=\"438\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 16px; font-weight: bold; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">rasdial / Windows VPN</tspan></text><text x=\"574\" y=\"475\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Built-in Windows VPN</tspan></text></g><g class=\"person-man\"><rect x=\"200\" y=\"692\" fill=\"#438DD5\" stroke=\"#3C7FC0\" width=\"428\" height=\"105\" rx=\"2.5\" ry=\"2.5\" stroke-width=\"0.5\"></rect><text fill=\"#FFFFFF\" font-family=\"&quot;Open Sans&quot;, sans-serif\" font-size=\"12\" font-style=\"italic\" lengthAdjust=\"spacing\" textLength=\"63\" x=\"382.5\" y=\"712\">&lt;&lt;container&gt;&gt;</text><text x=\"414\" y=\"730\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 16px; font-weight: bold; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">VPNManager.exe</tspan></text><text x=\"414\" y=\"752\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" font-style=\"italic\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">[C# WinForms / .NET]</tspan></text><text x=\"414\" y=\"786\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">System tray GUI. Manages cycle timer, settings, process lifecycle.</tspan></text></g><g class=\"person-man\"><rect x=\"200\" y=\"897\" fill=\"#438DD5\" stroke=\"#3C7FC0\" width=\"502\" height=\"105\" rx=\"2.5\" ry=\"2.5\" stroke-width=\"0.5\"></rect><text fill=\"#FFFFFF\" font-family=\"&quot;Open Sans&quot;, sans-serif\" font-size=\"12\" font-style=\"italic\" lengthAdjust=\"spacing\" textLength=\"63\" x=\"419.5\" y=\"917\">&lt;&lt;container&gt;&gt;</text><text x=\"451\" y=\"935\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 16px; font-weight: bold; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">VPN-AutoToggle.ps1</tspan></text><text x=\"451\" y=\"957\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" font-style=\"italic\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">[PowerShell 5.1+]</tspan></text><text x=\"451\" y=\"991\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Core toggle loop. Connects/disconnects VPN, waits cycle duration, logs state.</tspan></text></g><g class=\"person-man\"><path fill=\"#438DD5\" stroke-width=\"0.5\" stroke=\"#3C7FC0\" d=\"M200,1102c0,-10 225.5,-10 225.5,-10c0,0 225.5,0 225.5,10l0,105c0,10 -225.5,10 -225.5,10c0,0 -225.5,0 -225.5,-10l0,-105\"></path><path fill=\"none\" stroke-width=\"0.5\" stroke=\"#3C7FC0\" d=\"M200,1102c0,10 225.5,10 225.5,10c0,0 225.5,0 225.5,-10\"></path><text fill=\"#FFFFFF\" font-family=\"&quot;Open Sans&quot;, sans-serif\" font-size=\"12\" font-style=\"italic\" lengthAdjust=\"spacing\" textLength=\"83\" x=\"384\" y=\"1122\">&lt;&lt;container_db&gt;&gt;</text><text x=\"425.5\" y=\"1140\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 16px; font-weight: bold; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">settings.json</tspan></text><text x=\"425.5\" y=\"1162\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" font-style=\"italic\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">[JSON / AppData]</tspan></text><text x=\"425.5\" y=\"1196\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Persistent user config: VPN type, cycle time, MEGAsync path, theme.</tspan></text></g><g class=\"person-man\"><path fill=\"#438DD5\" stroke-width=\"0.5\" stroke=\"#3C7FC0\" d=\"M200,1307c0,-10 316,-10 316,-10c0,0 316,0 316,10l0,105c0,10 -316,10 -316,10c0,0 -316,0 -316,-10l0,-105\"></path><path fill=\"none\" stroke-width=\"0.5\" stroke=\"#3C7FC0\" d=\"M200,1307c0,10 316,10 316,10c0,0 316,0 316,-10\"></path><text fill=\"#FFFFFF\" font-family=\"&quot;Open Sans&quot;, sans-serif\" font-size=\"12\" font-style=\"italic\" lengthAdjust=\"spacing\" textLength=\"83\" x=\"474.5\" y=\"1327\">&lt;&lt;container_db&gt;&gt;</text><text x=\"516\" y=\"1345\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 16px; font-weight: bold; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">vpn-settings.json</tspan></text><text x=\"516\" y=\"1367\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" font-style=\"italic\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">[JSON / Temp]</tspan></text><text x=\"516\" y=\"1401\" dominant-baseline=\"middle\" fill=\"#FFFFFF\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Runtime bridge: GUI writes VPN params, PowerShell reads them to avoid CLI credential exposure.</tspan></text></g><g><rect x=\"150\" y=\"592\" fill=\"none\" stroke=\"#444444\" width=\"732\" height=\"870\" rx=\"2.5\" ry=\"2.5\" stroke-width=\"1\" stroke-dasharray=\"7.0,7.0\"></rect><text x=\"516\" y=\"600\" dominant-baseline=\"middle\" fill=\"#444444\" style=\"text-anchor: middle; font-size: 16px; font-weight: bold; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">VPN Manager</tspan></text><text x=\"516\" y=\"622\" dominant-baseline=\"middle\" fill=\"#444444\" style=\"text-anchor: middle; font-size: 14px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">[SYSTEM]</tspan></text></g><defs><marker id=\"arrowhead\" refX=\"9\" refY=\"5\" markerUnits=\"userSpaceOnUse\" markerWidth=\"12\" markerHeight=\"12\" orient=\"auto\"><path d=\"M 0 0 L 10 5 L 0 10 z\"></path></marker></defs><defs><marker id=\"arrowend\" refX=\"1\" refY=\"5\" markerUnits=\"userSpaceOnUse\" markerWidth=\"12\" markerHeight=\"12\" orient=\"auto\"><path d=\"M 10 0 L 0 5 L 10 10 z\"></path></marker></defs><defs><marker id=\"crosshead\" markerWidth=\"15\" markerHeight=\"8\" orient=\"auto\" refX=\"16\" refY=\"4\"><path fill=\"black\" stroke=\"#000000\" stroke-width=\"1px\" d=\"M 9,2 V 6 L16,4 Z\" style=\"stroke-dasharray: 0, 0;\"></path><path fill=\"none\" stroke=\"#000000\" stroke-width=\"1px\" d=\"M 0,1 L 6,7 M 6,1 L 0,7\" style=\"stroke-dasharray: 0, 0;\"></path></marker></defs><defs><marker id=\"filled-head\" refX=\"18\" refY=\"7\" markerWidth=\"20\" markerHeight=\"28\" orient=\"auto\"><path d=\"M 18,7 L9,13 L14,7 L9,1 Z\"></path></marker></defs><g><line x1=\"288.57562662057046\" y1=\"300\" x2=\"420.63398692810455\" y2=\"692\" stroke-width=\"1\" stroke=\"#444444\" marker-end=\"url(#arrowhead)\" style=\"fill: none;\"></line><text x=\"446.1048067743375\" y=\"496\" dominant-baseline=\"middle\" fill=\"#444444\" style=\"text-anchor: middle; font-size: 12px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Start/stop cycle, configure settings</tspan></text><path fill=\"none\" stroke-width=\"1\" stroke=\"#444444\" d=\"M465.1747572815534,797 Q480.0491007480503,847 524.672131147541,897 \" marker-end=\"url(#arrowhead)\"></path><text x=\"615.4234442145472\" y=\"847\" dominant-baseline=\"middle\" fill=\"#444444\" style=\"text-anchor: middle; font-size: 12px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Spawns PowerShell process with parameters</tspan></text><path fill=\"none\" stroke-width=\"1\" stroke=\"#444444\" d=\"M439.5972972972973,797 Q443.9296163296163,949.5 456.92657342657344,1102 \" marker-end=\"url(#arrowhead)\"></path><text x=\"523.7619353619353\" y=\"949.5\" dominant-baseline=\"middle\" fill=\"#444444\" style=\"text-anchor: middle; font-size: 12px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Read/write user preferences</tspan></text><path fill=\"none\" stroke-width=\"1\" stroke=\"#444444\" d=\"M438.85393258426967,797 Q463.13378277153555,1052 535.9733333333334,1307 \" marker-end=\"url(#arrowhead)\"></path><text x=\"592.9136329588015\" y=\"1052\" dominant-baseline=\"middle\" fill=\"#444444\" style=\"text-anchor: middle; font-size: 12px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Write VPN credentials + type at runtime</tspan></text><path fill=\"none\" stroke-width=\"1\" stroke=\"#444444\" d=\"M486.8702702702703,1002 Q503.36773766773763,1154.5 552.8601398601398,1307 \" marker-end=\"url(#arrowhead)\"></path><text x=\"603.365205065205\" y=\"1154.5\" dominant-baseline=\"middle\" fill=\"#444444\" style=\"text-anchor: middle; font-size: 12px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Read VPN type and credentials</tspan></text><path fill=\"none\" stroke-width=\"1\" stroke=\"#444444\" d=\"M479.5392441860465,897 Q502.948625864487,574.5 573.1767708998085,252 \" marker-end=\"url(#arrowhead)\"></path><text x=\"604.3580075429275\" y=\"574.5\" dominant-baseline=\"middle\" fill=\"#444444\" style=\"text-anchor: middle; font-size: 12px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">warp-cli connect / disconnect</tspan></text><path fill=\"none\" stroke-width=\"1\" stroke=\"#444444\" d=\"M494.2488986784141,897 Q513.8932254191836,691.5 572.8262056414923,486 \" marker-end=\"url(#arrowhead)\"></path><text x=\"608.0375521599532\" y=\"691.5\" dominant-baseline=\"middle\" fill=\"#444444\" style=\"text-anchor: middle; font-size: 12px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">rasdial connect / disconnect</tspan></text><path fill=\"none\" stroke-width=\"1\" stroke=\"#444444\" d=\"M457.70704845814976,897 Q413.66882137545946,691.5 281.55414012738856,486 \" marker-end=\"url(#arrowhead)\"></path><text x=\"470.63059429276916\" y=\"691.5\" dominant-baseline=\"middle\" fill=\"#444444\" style=\"text-anchor: middle; font-size: 12px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Kill + restart process after each toggle</tspan></text><path fill=\"none\" stroke-width=\"1\" stroke=\"#444444\" d=\"M426.2289156626506,692 Q392.4097128718065,589 290.9521044992743,486 \" marker-end=\"url(#arrowhead)\"></path><text x=\"455.0905100809624\" y=\"589\" dominant-baseline=\"middle\" fill=\"#444444\" style=\"text-anchor: middle; font-size: 12px; font-weight: normal; font-family: &quot;Open Sans&quot;, sans-serif;\"><tspan dy=\"0\" alignment-baseline=\"mathematical\">Monitor process status, display in UI</tspan></text></g><text x=\"266\" y=\"20\">Container Diagram — VPN Manager System</text></svg>","diagramType":"c4"}